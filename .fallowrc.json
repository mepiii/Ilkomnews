{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.{js,jsx,mjs}",
    "src/main.{js,jsx,mjs}"
  ],
  "duplicates": {
    // Hide pair-only clones; focus on widespread copy-paste
    // worth refactoring. Lower to 2 to report every duplicate pair.
    "minOccurrences": 3
    // Common additions (uncomment to enable):
    // "ignore": [
    //   "**/lib/**",          // for repos that publish transpiled output to lib/
    //   "**/legacy/**",       // for repos with legacy-build artifacts
    //   "**/__generated__/**", // Relay, GraphQL Code Generator
    //   "**/generated/**"     // OpenAPI, Protobuf codegen
    // ]
  },
  "rules": {
    "unused-dependencies": "warn"
  },
  "ignoreExports": [
    {
      "file": "ECC/scripts/lib/agent-proximity/distance.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/agent-proximity/index.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination/policy.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/install-lifecycle.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/install-manifests.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/install/request.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/install-executor.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination/actions.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/install/apply.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/agent-proximity/graph.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination/state.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination/gh-api.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination/store.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/github-coordination/parsing.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/hooks/post-edit-accumulator.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/hooks/stop-format-typecheck.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/session-bridge.js",
      "exports": ["*"]
    },
    {
      "file": "ECC/scripts/lib/utils.js",
      "exports": ["*"]
    }
  ]
}
