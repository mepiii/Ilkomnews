APP_NAME="ILKOM News"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ilkom
DB_USERNAME=root
DB_PASSWORD=

# Cache/Queue/Session all use file driver (no external services needed)
CACHE_STORE=file
QUEUE_CONNECTION=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optional, not used when cache/queue/session = file)
REDIS_CLIENT=phpredis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_PERSISTENT=true

GEMINI_API_KEY=
